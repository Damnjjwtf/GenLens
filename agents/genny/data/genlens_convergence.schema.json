{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://genlens.local/schemas/genlens_convergence.schema.json",
  "title": "GenLens Convergence Artifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_at",
    "ledger_schema_version",
    "latest_run_observed_at",
    "candidate_count",
    "verified_count",
    "rejected_count",
    "records"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "ledger_schema_version": {
      "type": "string"
    },
    "latest_run_observed_at": {
      "type": ["string", "null"]
    },
    "candidate_count": {
      "type": "integer",
      "minimum": 0
    },
    "verified_count": {
      "type": "integer",
      "minimum": 0
    },
    "rejected_count": {
      "type": "integer",
      "minimum": 0
    },
    "records": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/candidate"
      }
    }
  },
  "$defs": {
    "shared": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mechanisms", "workflows", "entities", "consequences"],
      "properties": {
        "mechanisms": {
          "type": "array",
          "items": {"type": "string"},
          "uniqueItems": true
        },
        "workflows": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string"},
          "uniqueItems": true
        },
        "entities": {
          "type": "array",
          "items": {"type": "string"},
          "uniqueItems": true
        },
        "consequences": {
          "type": "array",
          "items": {"type": "string"},
          "uniqueItems": true
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lens", "signal_id", "title", "url", "source_name", "published_at", "confidence"],
      "properties": {
        "lens": {"enum": ["genny", "marti"]},
        "signal_id": {"type": "string", "pattern": "^sig_[a-f0-9]{20}$"},
        "title": {"type": "string"},
        "url": {"type": "string"},
        "source_name": {"type": "string"},
        "published_at": {"type": ["string", "null"]},
        "confidence": {"enum": ["hypothesis", "single-source", "primary-source", "corroborated"]}
      }
    },
    "verification": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["id", "candidate_id", "status", "actor_id", "note", "conclusion", "idempotency_key", "recorded_at"],
      "properties": {
        "id": {"type": "string", "pattern": "^convr_[a-f0-9]{20}$"},
        "candidate_id": {"type": "string", "pattern": "^conv_[a-f0-9]{20}$"},
        "status": {"enum": ["verified", "rejected"]},
        "actor_id": {"type": "string", "minLength": 1},
        "note": {"type": "string", "minLength": 1},
        "conclusion": {"type": ["string", "null"]},
        "idempotency_key": {"type": "string", "minLength": 1},
        "recorded_at": {"type": "string", "format": "date-time"}
      }
    },
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "status",
        "confidence",
        "score",
        "genny_signal_id",
        "marti_signal_id",
        "shared",
        "hypothesis",
        "conclusion",
        "verification",
        "evidence"
      ],
      "properties": {
        "id": {"type": "string", "pattern": "^conv_[a-f0-9]{20}$"},
        "status": {"enum": ["candidate", "verified", "rejected"]},
        "confidence": {"enum": ["hypothesis", "human-verified", "rejected"]},
        "score": {"type": "integer", "minimum": 0},
        "genny_signal_id": {"type": "string", "pattern": "^sig_[a-f0-9]{20}$"},
        "marti_signal_id": {"type": "string", "pattern": "^sig_[a-f0-9]{20}$"},
        "shared": {"$ref": "#/$defs/shared"},
        "hypothesis": {"type": "string", "minLength": 1},
        "conclusion": {"type": ["string", "null"]},
        "verification": {"$ref": "#/$defs/verification"},
        "evidence": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": {"$ref": "#/$defs/evidence"}
        }
      }
    }
  }
}
