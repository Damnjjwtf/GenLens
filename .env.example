DATABASE_URL=postgres://user:pass@host.neon.tech/genlens?sslmode=require
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000
AUTH_SECRET=generate-with-openssl-rand-base64-32
AUTH_URL=http://localhost:3000
ANTHROPIC_API_KEY=sk-ant-xxx
RESEND_API_KEY=re_xxx
EMAIL_FROM=brief@yourdomain.com
CRON_SECRET=generate-with-openssl-rand-hex-32
PRODUCT_HUNT_TOKEN=
GITHUB_TOKEN=
INVITE_CODE_DEFAULT=GL-LAUNCH-0001

# OAuth — GitHub. Create at https://github.com/settings/developers
# Authorization callback URL: <AUTH_URL>/api/auth/callback/github
GITHUB_ID=
GITHUB_SECRET=

# Discord webhooks — one URL per channel. GENERAL is the fallback for any
# unrouted post. Missing channel-specific URLs fall through to GENERAL.
# Generate per channel: Server Settings → Integrations → Webhooks → New.
DISCORD_WEBHOOK_URL_GENERAL=
DISCORD_WEBHOOK_URL_ANNOUNCEMENTS=
DISCORD_WEBHOOK_URL_PP=
DISCORD_WEBHOOK_URL_FM=
DISCORD_WEBHOOK_URL_DH=
DISCORD_WEBHOOK_URL_TOOL_RELEASES=
DISCORD_WEBHOOK_URL_LEGAL_ALERTS=
DISCORD_WEBHOOK_URL_HIRING=
DISCORD_WEBHOOK_URL_TEMPLATES=
